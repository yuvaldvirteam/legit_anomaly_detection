import http from 'node:http';
import createHandler from 'github-webhook-handler';
import { PushChecker } from './src/checkers/pushChecker';
import { TeamsChecker } from './src/checkers/teamsChecker.ts';
import { RepositoryChecker } from './src/checkers/repositoryChecker.ts';

// Use environment variables for security
const WEBHOOK_SECRET = process.env.GITHUB_WEBHOOK_SECRET || 'test_secret';
const WEBHOOK_PATH = '/webhook';
const PORT = process.env.PORT || 3000;

// Create a handler for the webhook path and secret
const handler = createHandler({ path: WEBHOOK_PATH, secret: WEBHOOK_SECRET });

// Create a basic HTTP server
http.createServer((req, res) => {
  handler(req, res, (err) => {
    console.log(err);
    res.statusCode = 404;
    res.end('no such location');
  });
}).listen(PORT, () => {
  console.log(`Server listening on port ${PORT}`);
  console.log(`Webhook endpoint: http://127.0.0.1:${PORT}${WEBHOOK_PATH}`);
});

// Listen for specific events
handler.on('error', (err) => {
  console.error('Error handling webhook:', err.message);
});

handler.on('push', (event) => {
  const pushChecker = new PushChecker(event.payload);
  if (!pushChecker.check()) {
    console.log(pushChecker.getMessage());
  }
});

handler.on('team', (event) => {
  const teamsChecker = new TeamsChecker(event.payload);
  if (!teamsChecker.check()) {
    console.log(teamsChecker.getMessage());
  }
});

handler.on('repository', (event) => {
  const repositoryChecker = new RepositoryChecker(event.payload);
  if (!repositoryChecker.check()) {
    console.log(repositoryChecker.getMessage());
  }
});

